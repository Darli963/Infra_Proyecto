generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Concesionarias
// ---------------------------------------------------------------------------
model Dealership {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email        String   @unique
  passwordHash String   // bcrypt hash — reemplazado por Cognito sub en producción
  phone     String?
  address   String?
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  motorcycles      Motorcycle[]
  quoteRules       QuoteRule[]
  quoteSimulations QuoteSimulation[]

  @@map("dealerships")
}

// ---------------------------------------------------------------------------
// Motocicletas
// ---------------------------------------------------------------------------
model Motorcycle {
  id           String   @id @default(uuid())
  dealershipId String
  brand        String
  model        String
  year         Int
  engineCC     Int
  price        Decimal  @db.Decimal(12, 2)
  currency     String   @default("USD")
  category     String   // sport, touring, cruiser, off-road, scooter, etc.
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealership       Dealership       @relation(fields: [dealershipId], references: [id])
  images           MotorcycleImage[]
  quoteRules       QuoteRule[]
  quoteSimulations QuoteSimulation[]

  @@map("motorcycles")
}

// ---------------------------------------------------------------------------
// Imágenes de motocicletas
// ---------------------------------------------------------------------------
model MotorcycleImage {
  id           String   @id @default(uuid())
  motorcycleId String
  url          String   // URL S3 / CloudFront
  altText      String?
  isPrimary    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  motorcycle Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)

  @@map("motorcycle_images")
}

// ---------------------------------------------------------------------------
// Reglas de cotización
// Aplican a nivel concesionaria o a nivel moto (la moto tiene precedencia).
// ---------------------------------------------------------------------------
model QuoteRule {
  id           String   @id @default(uuid())
  dealershipId String
  motorcycleId String?  // null = regla global de la concesionaria
  name         String
  // Factor multiplicador sobre el precio base (p.ej. 1.05 = +5 %)
  factor       Decimal  @db.Decimal(6, 4)
  // Cargo fijo adicional (puede ser 0)
  fixedCharge  Decimal  @default(0) @db.Decimal(12, 2)
  currency     String   @default("USD")
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealership Dealership  @relation(fields: [dealershipId], references: [id])
  motorcycle Motorcycle? @relation(fields: [motorcycleId], references: [id])

  @@map("quote_rules")
}

// ---------------------------------------------------------------------------
// Preguntas de riesgo del cuestionario
// ---------------------------------------------------------------------------
model RiskQuestion {
  id           String       @id @default(uuid())
  text         String
  inputType    InputType    @default(SINGLE_CHOICE)
  required     Boolean      @default(true)
  sortOrder    Int          @default(0)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  options              RiskQuestionOption[]
  simulationResponses  SimulationResponse[]

  @@map("risk_questions")
}

enum InputType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
  NUMBER
  BOOLEAN

  @@map("input_type")
}

// ---------------------------------------------------------------------------
// Opciones de respuesta para preguntas de selección
// ---------------------------------------------------------------------------
model RiskQuestionOption {
  id             String   @id @default(uuid())
  questionId     String
  label          String
  // Factor de riesgo asociado a esta opción (1.0 = neutro, >1.0 = mayor riesgo)
  riskFactor     Decimal  @default(1.0) @db.Decimal(6, 4)
  sortOrder      Int      @default(0)

  question            RiskQuestion         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  simulationResponses SimulationResponse[]

  @@map("risk_question_options")
}

// ---------------------------------------------------------------------------
// Simulaciones de cotización
// ---------------------------------------------------------------------------
model QuoteSimulation {
  id             String          @id @default(uuid())
  dealershipId   String
  motorcycleId   String
  // Datos del solicitante (sin PII sensible en esta fase)
  applicantName  String
  applicantEmail String
  // Precio base al momento de la cotización
  basePrice      Decimal         @db.Decimal(12, 2)
  // Precio final calculado por el motor de cotización
  finalPrice     Decimal         @db.Decimal(12, 2)
  currency       String          @default("USD")
  status         SimulationStatus @default(DRAFT)
  expiresAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  dealership Dealership           @relation(fields: [dealershipId], references: [id])
  motorcycle Motorcycle           @relation(fields: [motorcycleId], references: [id])
  responses  SimulationResponse[]

  @@map("quote_simulations")
}

enum SimulationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("simulation_status")
}

// ---------------------------------------------------------------------------
// Respuestas del cuestionario de riesgo dentro de una simulación
// ---------------------------------------------------------------------------
model SimulationResponse {
  id           String  @id @default(uuid())
  simulationId String
  questionId   String
  optionId     String? // null cuando la respuesta es texto libre o numérica
  textValue    String? // para InputType TEXT / NUMBER / BOOLEAN

  simulation QuoteSimulation    @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  question   RiskQuestion       @relation(fields: [questionId], references: [id])
  option     RiskQuestionOption? @relation(fields: [optionId], references: [id])

  @@unique([simulationId, questionId])
  @@map("simulation_responses")
}
