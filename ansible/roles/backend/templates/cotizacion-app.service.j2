[Unit]
Description=Cotizacion Backend Application
After=network.target

[Service]
Type=simple
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/cotizacion-app/current
EnvironmentFile=/opt/cotizacion-app/current/.env
ExecStart=/usr/bin/node start.js
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cotizacion-app

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/cotizacion-app/current
RestrictAddressFamilies=AF_INET AF_INET6
RestrictRealtime=true
SystemCallFilter=@system-service

[Install]
WantedBy=multi-user.target
